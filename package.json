{
  "name": "pipeline-pling",
  "version": "1.0.0",
  "private": true,
  "description": "Post GitHub push commit notifications to Discord using Components V2",
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --outfile=dist/index.js --format=cjs --minify",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test && npm run build",
    "act:test": "node scripts/act-test.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1"
  }
}
